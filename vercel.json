{
  "version": 2,
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.ts"
    },
    {
      "src": "/index.html",
      "dest": "/index.html"
    },
    {
      "src": "/resume.html",
      "dest": "/resume.html"
    },
    {
      "src": "/style.css",
      "dest": "/style.css"
    },
    {
      "src": "/app.js",
      "dest": "/app.js"
    },
    {
      "src": "/data.js",
      "dest": "/data.js"
    },
    {
      "src": "/(.*)",
      "dest": "api/index.ts"
    }
  ]
}
